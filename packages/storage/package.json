{
  "name": "@pnpm-test-workspace/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@pnpm-test-workspace/eslint-config": "workspace:*",
    "@pnpm-test-workspace/tsconfig": "workspace:*",
    "@types/node": "^20.11.17",
    "eslint": "^9.17.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-presigned-post": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  }
}
