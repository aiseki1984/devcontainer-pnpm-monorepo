{
  "name": "@pnpm-test-workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "pnpm --filter @pnpm-test-workspace/auth build && tsx src/seed.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\"",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@pnpm-test-workspace/auth": "workspace:*",
    "@pnpm-test-workspace/eslint-config": "workspace:*",
    "@pnpm-test-workspace/tsconfig": "workspace:*",
    "@types/node": "^20.11.17",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": "prettier --write"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  }
}
