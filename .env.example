# このファイルは「どの環境変数が必要か」を示すテンプレート。コミットして共有する。
# devcontainer では自動生成せず、必要に応じて cp .env.example .env で明示的に作成する。
# ローカル開発では root の npm scripts が dotenv-cli で .env を読み込む。
# CI / 本番では .env ではなく、実行環境の env / secrets / secret manager から供給する。
# 既に本物の環境変数があれば、.env ファイルより優先される。

# DB 接続先（packages/db, apps/api の実行時）
DATABASE_URL=postgres://dev:dev@postgres:5432/todo_dev

# API の CORS 許可 origin（apps/api）
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# API のポート（apps/api）。汎用の PORT は Next.js も読んでしまい web と衝突するため専用名にする。
API_PORT=8787

# web が叩く API の URL（apps/web、ビルド時に埋め込まれる）
NEXT_PUBLIC_API_URL=http://localhost:8787

# JWT 署名鍵（Step 9 以降で使用）。本番はランダムな値に置き換える。
JWT_SECRET=replace-with-at-least-32-random-characters

# オブジェクトストレージ（Garage / S3 互換。apps/api がアバター画像の presigned URL を発行）。
# S3_ENDPOINT は「ブラウザが presigned URL で直接叩く先」を指定する。presign は
# オフラインの署名計算なので、コンテナ内からの到達性ではなく署名に埋まる host が一致するかが重要。
# ホストのブラウザは localhost:3900 で Garage に届くため、ここは localhost を使う。
# 初期化（layout/bucket/key/CORS）と S3_ACCESS_KEY/S3_SECRET_KEY の取得手順は README 参照。
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_BUCKET=avatars
S3_ACCESS_KEY=replace-with-garage-access-key-id
S3_SECRET_KEY=replace-with-garage-secret-key
