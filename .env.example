# このファイルは「どの環境変数が必要か」を示すテンプレート。コミットして共有する。
# devcontainer では自動生成せず、必要に応じて cp .env.example .env で明示的に作成する。
# ローカル開発では root の npm scripts が dotenv-cli で .env を読み込む。
# CI / 本番では .env ではなく、実行環境の env / secrets / secret manager から供給する。
# 既に本物の環境変数があれば、.env ファイルより優先される。

# DB 接続先（packages/db, apps/api の実行時）
DATABASE_URL=postgres://dev:dev@postgres:5432/todo_dev

# API の CORS 許可 origin（apps/api）
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# API のポート（apps/api）。汎用の PORT は Next.js も読んでしまい web と衝突するため専用名にする。
API_PORT=8787

# web が叩く API の URL（apps/web、ビルド時に埋め込まれる）
NEXT_PUBLIC_API_URL=http://localhost:8787

# JWT 署名鍵（Step 9 以降で使用）。本番はランダムな値に置き換える。
JWT_SECRET=replace-with-at-least-32-random-characters

# オブジェクトストレージ（Garage / S3 互換。apps/api がアバター画像の presigned URL を発行）。
# S3_ENDPOINT は「ブラウザが presigned URL で直接叩く先」を指定する。presign は
# オフラインの署名計算なので、コンテナ内からの到達性ではなく署名に埋まる host が一致するかが重要。
# ホストのブラウザは localhost:3900 で Garage に届くため、ここは localhost を使う。
#
# S3_INTERNAL_ENDPOINT は「apps/api 自身が直接 Garage に接続する先」（GetObject での内容検証・
# 不正オブジェクト削除など）。presigned URL と違い API プロセスが接続するため、コンテナから
# 到達できる host が必要。devcontainer では API から localhost:3900 には届かないので
# サービス名 garage:3900 を使う。未設定なら S3_ENDPOINT にフォールバック（両者が同じ本番など）。
#
# バケットは公開/非公開の2系統。
# - S3_PUBLIC_BUCKET: 匿名 read（avatar/logo）。読み取りは website エンドポイント経由の固定 URL。
#   compose の GARAGE_DEFAULT_BUCKET で起動時に自動作成されるが、匿名公開（website --allow）と
#   CORS は手動（README 参照）。
# - S3_PRIVATE_BUCKET: presigned でしか読めない（gallery 等の私的ファイル）。ギャラリー機能で使う。
# S3_PUBLIC_BASE_URL: 公開バケットの **ブラウザ向け** ベース URL（Garage website / :3902）。
#   公開オブジェクトの URL は `${S3_PUBLIC_BASE_URL}/${key}` で組み立てる。vhost 形式
#   `<bucket>.web.localhost` は主要ブラウザが 127.0.0.1 に解決する。
#
# ACCESS_KEY / SECRET_KEY は compose.yml の GARAGE_DEFAULT_* と一致させること。
# dev 専用の固定値。本番は実環境の secret manager 等から供給する。
S3_ENDPOINT=http://localhost:3900
S3_INTERNAL_ENDPOINT=http://garage:3900
S3_REGION=garage
S3_PUBLIC_BUCKET=media-public
S3_PRIVATE_BUCKET=media-private
S3_PUBLIC_BASE_URL=http://media-public.web.localhost:3902
S3_ACCESS_KEY=GK0123456789abcdef01234567
S3_SECRET_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
